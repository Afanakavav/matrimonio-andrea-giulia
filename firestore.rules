rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // RSVP: creazione pubblica senza scadenza, lettura pubblica (admin legge tutto).
    // Update e delete bloccati: modifiche legittime vanno fatte via Firebase Admin SDK
    // (Cloud Functions con privilegi admin), mai direttamente dall'API pubblica.
    match /rsvp-confirmations/{document=**} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'attendance'])
                    && request.resource.data.name is string
                    && request.resource.data.email is string
                    && request.resource.data.attendance is string
                    && request.resource.data.email.matches('.*@.*\\..*');

      allow read: if true;

      // Nessuno può modificare un RSVP già inviato via API pubblica
      allow update: if false;

      // Delete bloccato per evitare vandalismo. Usa Firebase Admin SDK / Cloud Functions.
      allow delete: if false;
    }

    // Media: creazione/lettura pubblica nel periodo del matrimonio.
    // Update e delete bloccati: operazioni admin vanno fatte via Firebase Admin SDK.
    match /wedding-media/{document=**} {
      allow create: if request.time >= timestamp.date(2026, 7, 4)
                    && request.time < timestamp.date(2026, 7, 20);

      allow read: if true;

      // Nessuno può modificare i metadata di un media già caricato via API pubblica
      allow update: if false;

      // Delete bloccato per evitare vandalismo. Usa Firebase Admin SDK / Cloud Functions.
      allow delete: if false;
    }
  }
}
