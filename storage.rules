rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // wedding-media: upload dagli invitati
    match /wedding-media/{folder}/{fileName} {

      // Read pubblico (per galleria pubblica)
      allow read: if true;

      // Upload permesso da 9 maggio a 19 luglio 2026
      // Solo cartelle valide: originals, display, thumbs
      // File size max 100MB, tipo image/* o video/*
      //
      // IMPORTANTE: il client DEVE passare contentType nei metadata di ogni
      // chiamata ref.put(blob, metadata), altrimenti request.resource.contentType
      // è undefined e la rule nega con 403. Vedi upload-flow.js → uploadFile().
      allow create: if
        folder in ['originals', 'display', 'thumbs'] &&
        request.time >= timestamp.date(2026, 5, 9) &&
        request.time <= timestamp.date(2026, 7, 19) &&
        (request.resource.contentType.matches('image/.*') ||
         request.resource.contentType.matches('video/.*')) &&
        request.resource.size < 100 * 1024 * 1024;

      // Update e delete solo via Admin SDK
      allow update: if false;
      allow delete: if false;
    }

    // Tutto il resto: nega
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
