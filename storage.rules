rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // wedding-media: upload dagli invitati
    match /wedding-media/{folder}/{fileName} {

      // Read pubblico (per galleria pubblica)
      allow read: if true;

      // Upload permesso da 9 maggio a 19 luglio 2026
      // Solo cartelle valide: originals, display, thumbs
      // File size max 100MB
      //
      // Validazione contentType rimossa: risulta inaffidabile per
      // uploadBytesResumable (request.resource undefined nel chunk start).
      // Validazione enforced lato client (input accept, metadata in put()).
      // Cloud Function generateThumbnails (Settimana 2 Giorno 4) rifiuterà
      // file non-immagine/video in pipeline server-side.
      allow create: if
        // Richiede auth (anche anonimo)
        request.auth != null &&
        folder in ['originals', 'display', 'thumbs'] &&
        request.time >= timestamp.date(2026, 5, 9) &&
        request.time <= timestamp.date(2026, 7, 19) &&
        request.resource.size < 100 * 1024 * 1024;

      // Update e delete solo via Admin SDK
      allow update: if false;
      allow delete: if false;
    }

    // Tutto il resto: nega
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
