rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // wedding-media: upload dagli invitati
    match /wedding-media/{folder}/{fileName} {

      // Read pubblico (per galleria pubblica)
      allow read: if true;

      // Validazione size delegata al client (compressione + UI limit) e
      // gestita anche server-side dalla Cloud Function generateThumbnails
      // (rifiuta file non-immagine). Il check size nelle rules è rimosso
      // perché request.resource.size è undefined nel chunk start di
      // uploadBytesResumable.
      allow create: if
        request.auth != null &&
        folder in ['originals', 'display', 'thumbs'] &&
        request.time >= timestamp.date(2026, 5, 9) &&
        request.time <= timestamp.date(2026, 7, 19);

      // Update e delete solo via Admin SDK
      allow update: if false;
      allow delete: if false;
    }

    // Tutto il resto: nega
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
